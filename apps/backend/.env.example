# Use a DB user that exists on your Postgres instance (see `psql -c "\\du"`).
# Homebrew Postgres on macOS: superuser is often your macOS username, not "postgres".
#   postgresql://YOUR_USERNAME@localhost:5432/lapkin_db
# Official Postgres.app / Docker image: user "postgres" is common.
#   postgresql://postgres:password@localhost:5432/lapkin_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/lapkin_db
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
PORT=3000
COOKIE_SECRET=your-cookie-secret-change-in-production
FRONTEND_URL=http://localhost:5173
