# API origin (no trailing path). Baked in at `npm run build` — set in CI or `.env.production`.
# REST: <origin>/api  ·  Socket.IO: <same origin>/socket.io (browser uses ws: or wss: from the URL scheme).
# Production example:
# VITE_API_URL=https://api.lapkin.ftsdigihouse.com
#
# If you omit this in production, the app uses the page origin for API + sockets; nginx (or similar)
# must proxy /api and /socket.io to the backend, and for /socket.io set WebSocket upgrade headers.
#
# Local dev (direct to backend; ensure backend CORS allows the Vite origin):
VITE_API_URL=http://localhost:8087
